# Environment Variables for CodeSage

# ============================================
# AI Provider Configuration (Required)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_INPUT_COST_PER_MILLION_TOKENS=0
OPENAI_OUTPUT_COST_PER_MILLION_TOKENS=0

# OR use Claude (fallback)
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_API_VERSION=2023-06-01
CLAUDE_INPUT_COST_PER_MILLION_TOKENS=0
CLAUDE_OUTPUT_COST_PER_MILLION_TOKENS=0

# Shared AI HTTP policy
CODESAGE_AI_REQUEST_TIMEOUT=30s
CODESAGE_AI_MAX_DIFF_CHARS=60000
CODESAGE_AI_RETRY_MAX_ATTEMPTS=2
CODESAGE_AI_RETRY_BACKOFF=250ms

# ============================================
# GitHub App Configuration (Optional for local dev)
# ============================================
# Follow setup guide: docs/github-integration.md
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem
GITHUB_INSTALLATION_ID=987654
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ============================================
# Database Configuration
# ============================================
# Default values work with docker-compose
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# ============================================
# Message Queue Configuration
# ============================================
# Default values work with docker-compose
RABBITMQ_USERNAME=codesage
RABBITMQ_PASSWORD=replace-with-a-strong-queue-password

# ============================================
# Docker Hub (for CI/CD)
# ============================================
DOCKER_USERNAME=your-dockerhub-username
DOCKER_PASSWORD=your-dockerhub-password
